#!/bin/sh

# Redirect output to stderr.
exec 1>&2

echo 'Running pre-push hooks...'

remote_name="$1"

# Read the ref lines that git passes on stdin.
# Each line: <local_ref> <local_sha> <remote_ref> <remote_sha>
while read -r _local_ref _local_sha remote_ref _remote_sha; do
    case "$remote_ref" in
        refs/heads/main|refs/heads/master)
            if [ "$remote_name" = "dokku" ]; then
                echo "⚡ Deploying to Dokku..."
            else
                echo "❌ Direct pushes to ${remote_ref#refs/heads/} are not allowed. Please use PRs!"
                exit 1
            fi
            ;;
    esac
done

echo "✅ All pre-push checks passed!"
exit 0
