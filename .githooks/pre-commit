#!/bin/sh

# Redirect output to stderr.
exec 1>&2

echo 'Running pre-commit hooks...'

# Check if backend files changed
if git diff --cached --name-only | grep -q "^backend/"; then
    echo "=> 🐍 Backend files modified. Running checks..."
    
    cd backend || exit 1

    # Activate the project venv so ruff/mypy/pytest are available.
    # shellcheck disable=SC1091
    . .venv/bin/activate
    
    echo ">> Running ruff check..."
    ruff check .
    if [ $? -ne 0 ]; then
        echo "❌ ruff check failed! Please fix linting errors."
        exit 1
    fi

    echo ">> Running ruff format --check..."
    ruff format --check .
    if [ $? -ne 0 ]; then
        echo "❌ ruff format failed! Run 'ruff format .' to fix formatting."
        exit 1
    fi

    echo ">> Running mypy..."
    mypy app
    if [ $? -ne 0 ]; then
        echo "❌ mypy failed! Please fix type errors."
        exit 1
    fi

    echo ">> Running pytest..."
    pytest
    if [ $? -ne 0 ]; then
        echo "❌ pytest failed! Please fix failing tests."
        exit 1
    fi
    
    cd ..
fi

# Check if Flutter app files changed
if git diff --cached --name-only | grep -q "^app/"; then
    echo "=> 🐦 Flutter app files modified. Running checks..."
    
    cd app || exit 1

    # Add Flutter to PATH if not already present.
    for flutter_candidate in \
        "$HOME/development/flutter/bin" \
        "$HOME/flutter/bin" \
        "/opt/flutter/bin"; do
        if [ -x "$flutter_candidate/flutter" ]; then
            export PATH="$flutter_candidate:$PATH"
            break
        fi
    done

    echo ">> Running build_runner..."
    dart run build_runner build --delete-conflicting-outputs
    if [ $? -ne 0 ]; then
        echo "❌ build_runner failed! Please fix code generation errors."
        exit 1
    fi

    echo ">> Running flutter analyze..."
    flutter analyze
    if [ $? -ne 0 ]; then
        echo "❌ flutter analyze failed! Please fix dart warnings/errors."
        exit 1
    fi

    echo ">> Running flutter test..."
    flutter test
    if [ $? -ne 0 ]; then
        echo "❌ flutter test failed! Please fix failing tests."
        exit 1
    fi
    
    cd ..
fi

echo "✅ All pre-commit checks passed!"
exit 0
