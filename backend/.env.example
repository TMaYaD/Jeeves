# development | test | production
JEEVES_ENV=development
JEEVES_DATABASE_URL=postgresql+asyncpg://jeeves:jeeves@localhost:5432/jeeves
JEEVES_ELECTRIC_URL=http://localhost:3000
# WARNING: change this to a long random value in production (e.g. `openssl rand -hex 32`)
# This key is also referenced by Electric SQL as AUTH_JWT_KEY in docker-compose.yml
JEEVES_SECRET_KEY=changeme-in-production
JEEVES_ANTHROPIC_API_KEY=sk-ant-...
JEEVES_REDIS_URL=redis://localhost:6379/0
JEEVES_FIREBASE_CREDENTIALS_PATH=
# Comma-separated list of allowed CORS origins (default: * for dev)
# JEEVES_ALLOWED_ORIGINS=https://your-flutter-app.example.com
