# development | test | production
APP_ENV=development
DATABASE_URL=postgresql+asyncpg://jeeves:jeeves@localhost:5432/jeeves
POWERSYNC_URL=http://localhost:8080
# WARNING: change this to a long random value in production (e.g. `openssl rand -hex 32`)
# This key is also used by PowerSync (as PS_JEEVES_SECRET_KEY_B64 in sync-config.yaml)
SECRET_KEY=changeme-in-production
ANTHROPIC_API_KEY=sk-ant-...
REDIS_URL=redis://localhost:6379/0
FIREBASE_CREDENTIALS_PATH=
# Comma-separated list of allowed CORS origins (default: * for dev)
# ALLOWED_ORIGINS=https://your-flutter-app.example.com
